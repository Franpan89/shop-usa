generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  clients  Client[]
  orders   Order[]
  boxes    Box[]
  expenses Expense[]
}

model User {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  email     String   @unique
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  SUPERADMIN
  ADMIN
  STAFF
}

model Client {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  code      String
  name      String
  idNumber  String?
  country   String
  city      String
  phone           String
  birthday        DateTime?
  notes           String?
  deliveryMethod  DeliveryMethod @default(STORE_PICKUP)
  deliveryAddress String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orders    Order[]
}

enum DeliveryMethod {
  STORE_PICKUP
  HOME_DELIVERY
}

model Order {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  boxId       String?
  box         Box?     @relation(fields: [boxId], references: [id])
  
  orderDate   DateTime @default(now())
  status      String   @default("PENDING") // PENDING, IN_TRANSIT, DELIVERED
  totalAmount Float    @default(0)
  balance     Float    @default(0)
  products    Product[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id            String      @id @default(cuid())
  orderId       String
  order         Order       @relation(fields: [orderId], references: [id])
  name          String
  weight        Float
  purchasedBy   PurchasedBy @default(CLIENT)
  purchaseValue Float?
  prepaidAmount Float       @default(0)
  shippingCost  Float       @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

enum PurchasedBy {
  CLIENT
  SHOPUSA
}

enum OrderStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
}

model Box {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  internalId  String
  size        String
  status      BoxStatus @default(IN_TRANSIT)
  country     String
  totalWeight Float
  
  orders      Order[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum BoxStatus {
  IN_TRANSIT
  DELIVERED
}

model Expense {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  expenseDate     DateTime
  category        String
  description     String
  country         String
  originalAmount  Float
  adjustedAmount  Float

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
